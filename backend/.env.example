# ===== Sistema de Códigos de Verificación (VeriCode) =====
# Variables de entorno para el backend.
# Copiar este archivo a `.env` y editar antes de producción.

APP_NAME=Sistema de Códigos de Verificación

# SQLAlchemy URL. SQLite por defecto; para PostgreSQL cambiar a:
# DATABASE_URL=postgresql://vericode:vericode_pass@localhost:5432/vericode
DATABASE_URL=sqlite:///./codigos.db

# === JWT ===
# Cualquier string aleatorio largo (mínimo 32 caracteres).
SECRET_KEY=CHANGE-ME-dev-secret-key-do-not-use-in-production-please
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Internos
POLL_INTERVAL_SECONDS=30
# IMAP IDLE — tiempo máximo por ciclo (RFC 2177, máx 29 min = 1740 s).
# El servidor notifica al backend en tiempo real cuando llega un correo.
# Por defecto 28 minutos; tras ese lapso el backend re-entra en IDLE.
#IMAP_IDLE_TIMEOUT=1680

# === Cifrado de passwords IMAP (Fernet) ===
# Generar con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANTE: si rotás esta clave, los passwords en BD dejan de poder
# descifrarse. Hacer un script de migración antes de cambiarla.
FERNET_KEY=2s9SHRQ36vwyY1g8VZEiVCdJ7W7Czt7ynFfv4vsyiZg=

# === CORS ===
# Lista separada por comas de los orígenes permitidos.
# IMPORTANTE: incluir el esquema (http://) y sin barra final.
# Si usás '*', el backend deshabilita credenciales (recomendado sólo para dev).
CORS_ORIGINS=https://vericode.dpdns.org,http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000
